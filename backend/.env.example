# N_Mornitoring v3 백엔드 환경 변수
# 이 파일을 복사해서 .env로 저장 후 값을 채워넣으세요.

# 로그 레벨: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 크롤러 설정
CRAWLER_MAX_WORKERS=3        # 병렬 브라우저 최대 수 (권장: 2-4)
CRAWLER_POST_LIMIT=3         # 게시글 최대 방문 수
CRAWLER_TIMEOUT_MS=30000     # 페이지 로드 타임아웃 (밀리초)

# 스케줄러
SCHEDULER_INTERVAL_HOURS=1   # 자동 검증 실행 간격 (시간)
